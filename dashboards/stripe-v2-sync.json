        { "expr": "histogram_quantile(0.95, sum(rate(stripe_sync_process_row_latency_seconds_bucket[$__rate_interval])) by (le))", "refId": "B", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(stripe_sync_process_row_latency_seconds_bucket[$__rate_interval])) by (le))", "refId": "C", "legendFormat": "p99" }
      ],
      "title": "Process row latency (alert p95 >30s for 5m)",
