        { "expr": "sum(rate(stripe_sync_pause_in_process_total[$__rate_interval]))", "refId": "B", "legendFormat": "pause in-process (E1)" },
        { "expr": "sum(rate(stripe_sync_coalesced_rows_total[$__rate_interval]))", "refId": "C", "legendFormat": "coalesced rows" },
        { "expr": "sum(rate(stripe_sync_blocked_no_account_total[$__rate_interval]))", "refId": "D", "legendFormat": "blocked no_account" }
      ],
      "title": "Reaper / pause / coalesce activity",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "sophosic-prometheus" },
