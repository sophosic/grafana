        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "sum(rate(stripe_v2_webhook_received_total[$__rate_interval]))", "refId": "A", "legendFormat": "webhook received" },
        { "expr": "sum(rate(stripe_v2_webhook_signature_failed_total[$__rate_interval]))", "refId": "B", "legendFormat": "signature failed" },
        { "expr": "sum(rate(stripe_v2_drift_detected_total[$__rate_interval]))", "refId": "C", "legendFormat": "drift detected" }
      ],
      "title": "Webhooks + drift detection",
      "type": "timeseries"
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 40,
      "title": "Worker liveness (KAN-519 Theme E2)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "sophosic-prometheus" },
      "description": "Worker bootstrap watchdog: rate of drain-loop iterations across all process instances. If this drops to 0 for 5+ minutes, the worker has hung, crashed, or failed to bootstrap — the rest of this dashboard's metrics will read as deceptively healthy (because nothing is generating new failures either). Alert rule: `rate(stripe_sync_poll_iterations_total[5m]) == 0` for 5m, severity=critical, runbook checks Render service status + worker logs + broker connectivity.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "auto",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.001 }
            ]
          },
          "unit": "cps"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 33 },
      "id": 41,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "sum(rate(stripe_sync_poll_iterations_total[$__rate_interval]))", "refId": "A", "legendFormat": "poll iterations / sec (all workers)" }
      ],
      "title": "Poll iterations rate (alert == 0 for 5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "sophosic-prometheus" },
      "description": "Instant liveness pill: GREEN if the worker emitted at least one poll iteration in the last 5 minutes, RED if zero. Pair with the time-series panel to distinguish a brief gap (transient broker hiccup) from a sustained outage (worker dead).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "DEAD" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 33 },
      "id": 42,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        { "expr": "sum(increase(stripe_sync_poll_iterations_total[5m]))", "refId": "A", "legendFormat": "iterations in last 5m" }
      ],
      "title": "Worker liveness (last 5m)",
      "type": "stat"
    }
  ],
